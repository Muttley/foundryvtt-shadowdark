<div
	class="shadowdark chat-card item-card"
	data-actor-id="{{actor._id}}"
	data-item-id="{{item._id}}"
>
	<header class="card-header flexrow"
		{{#if description }}
			data-action="expandDescription"
		{{/if}}
	>
		<img src="{{item.img}}" data-tooltip="{{item.name}}"/>
		<h3 class="item-name">{{item.name}}
			{{#if description}}
				<i class="fa-thin fa-caret-{{#if shortDesc}}down{{else}}right{{/if}}"></i>
			{{/if}}
		</h3>
	</header>

	<div class="card-content {{#if shortDesc}}expanded{{/if}}">
		<div class="wrapper">
			{{{description}}}
		</div>
	</div>

	<footer class="card-footer">
		<ul class="tags">
			{{#each itemProperties}}
				<li class="tag tag_primary tag_small">
					{{this.name}}
				</li>
			{{/each}}
			{{#if item.system.stashed}}
				<li class="tag tag_secondary tag_small">
					{{localize 'SHADOWDARK.item.stashed.label'}}
				</li>
			{{/if}}
		</ul>
	</footer>
</div>
