<divclass="shadowdark chat-card">
	{{#if mainRoll.html}}
		{{{mainRoll.html}}}
	{{/if}}

	{{#if item}}
		<a data-link data-uuid="{{item.uuid}}">
			<img src="{{item.img}}" style="width:20px;height:20px;display:inline">
			<span>{{item.name}}</span>
		</a>
	{{/if}}

	{{#each descriptions}}
		{{{this}}}
	{{/each}}

	{{#if damageRoll.html}}
		{{{damageRoll.html}}}
	{{else}}
		{{#if damageRoll.needed}}
			<div data-action="expandRoll">
				<button data-action="rollDamage">
					Roll Damage
				</button>
			</div>
		{{/if}}
	{{/if}}

	{{#if target}}
	<div class="target">
		<img src="{{target.texture.src}}" style="width:20px;height:20px;display:inline">
		<span>{{target.name}}</span>
	{{/if}}
</div>
