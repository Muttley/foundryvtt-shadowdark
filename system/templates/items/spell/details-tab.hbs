<section class="tab tab-details" data-group="primary" data-tab="tab-details">
	<div class="grid-3-columns">
		<div class="grid-colspan-3 grid-2-columns">

			<!-- Spell Name and Casting Class-->
			{{#> ui/sd-box
				header-label=(localize "SHADOWDARK.item.spell.label")
				header-class="light"
				content-class="SD-grid"
			}}
				<h3>{{localize 'SHADOWDARK.item.spell_tier'}}</h3>
				<div class="grid-2-columns">
					{{numberInput
						system.tier
						name="system.tier"
						class="spell-tier-value"
						placeholder="0"
					}}
					<div style="text-align: center">
						<h3>{{localize "SHADOWDARK.class-ability.dc.label"}}</h3> {{system.dc}}
					</div>
				</div>

				<h3>{{localize "SHADOWDARK.item.spell_duration"}}</h3>
				{{> items/_partials/duration
					base="system.duration"
					duration=system.duration
					type="spell"
					choices=config.SPELL_DURATIONS
					variableDuration=variableDuration
				}}

				<h3>{{localize 'SHADOWDARK.item.spell_range'}}</h3>
				<select name="system.range">
					<option value="">&mdash;</option>
					{{selectOptions
						config.SPELL_RANGES
						selected=system.range
						localize=false
					}}
				</select>
			{{/ui/sd-box}}

			{{#> ui/sd-box
				header-label=(localize "SHADOWDARK.item.spell_caster_classes")
				header-class="light"
			}}
				{{>
				items/_partials/choice-selector
				config=spellcasterClassesConfig
				editable=editable
				}}
			{{/ui/sd-box}}

		</div>
	</div>
</section>
